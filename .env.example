# Database
DATABASE_URL=postgresql+asyncpg://invoice_user:invoice_pass@localhost:5432/invoice_db

# Redis
REDIS_URL=redis://localhost:6379/0

# IMAP Email (for fetching invoice emails)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your_email@gmail.com
IMAP_PASS=your_app_password

# SMTP Email (for sending confirmations)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Accounting Portal
ACCOUNTING_PORTAL_URL=https://your-accounting-portal.com
ACCOUNTING_USER=admin@company.com
ACCOUNTING_PASS=your_portal_password

# File Paths
INVOICE_WATCH_FOLDER=/data/invoices/incoming
SCREENSHOTS_DIR=/data/screenshots

# Logging
LOG_LEVEL=INFO
